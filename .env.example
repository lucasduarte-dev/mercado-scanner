# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.railway.app

# Database (Railway provides this automatically, but you can override)
DATABASE_URL=postgresql://user:password@localhost:5432/mercado_scanner

# Google Sheets Credentials (JSON string)
GOOGLE_CREDENTIALS={"type": "service_account", "project_id": "...", "private_key": "..."}
GOOGLE_SHEET_ID=your-sheet-id

# Mercado Libre Tokens (JSON string)
MELI_TOKENS=[{"access_token": "...", "refresh_token": "...", "user_id": 123, ...}]
